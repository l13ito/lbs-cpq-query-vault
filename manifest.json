{
  "manifest_version": 3,
  "name": "Salesforce Query Vault",
  "version": "1.0.0",
  "description": "SOQL query library and clipboard helper for Salesforce Inspector and Salesforce Inspector Reloaded.",
  "permissions": ["storage", "tabs", "activeTab"],
  "action": {
    "default_title": "Salesforce Query Vault"
  },
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "salesforce-query-vault@example.com",
      "strict_min_version": "121.0"
    }
  }
}